# Database
DATABASE_URL=postgresql+psycopg://root:123456@localhost:5430/english_app_db

# Initial Admin Account
FIRST_ADMIN_USERNAME=your_admin_username_here
FIRST_ADMIN_EMAIL=your_admin_email_here
FIRST_ADMIN_PASSWORD=your_admin_password_here

# Authentication / JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=your_access_token_expiration_minutes_here
REFRESH_TOKEN_EXPIRE_DAYS=your_refresh_token_expiration_days_here

# Timezone
APP_TIMEZONE=your_timezone_here